        {
          "name": "OAuth Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Response is JSON\", function () {",
                  "  pm.response.to.have.header(\"Content-Type\");",
                  "});",
                  "let data = {};",
                  "try { data = pm.response.json(); } catch (error) {}",
                  "const candidates = [\"data.accessToken\",\"accessToken\"];",
                  "function pick(obj, path) {",
                  "  return path.split(\".\").reduce((acc, key) => (acc && acc[key] !== undefined ? acc[key] : undefined), obj);",
                  "}",
                  "for (const path of candidates) {",
                  "  const value = pick(data, path);",
                  "  if (typeof value === \"string\" && value.length > 0) {",
                  "    pm.collectionVariables.set(\"oauthToken\", value);",
                  "    break;",
                  "  }",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let data = {};",
                  "try { data = pm.response.json(); } catch (error) {}",
                  "const refreshToken = data?.data?.refreshToken || data?.refreshToken;",
                  "if (typeof refreshToken === \"string\" && refreshToken.length > 0) {",
                  "  pm.collectionVariables.set(\"oauthRefreshToken\", refreshToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"grant_type\": \"client_credentials\",\n  \"institutionId\": \"{{institutionId}}\",\n  \"client_assertion_type\": \"urn:ietf:params:oauth:client-assertion-type:jwt-bearer\",\n  \"client_assertion\": \"paste-client-assertion-jwt-here\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{scheme}}://{{baseUrl}}/institutions/oauth/token",
              "protocol": "{{scheme}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "institutions",
                "oauth",
                "token"
              ]
            },
            "description": "Exchange client assertion for access token. Also captures `{{oauthToken}}` and `{{oauthRefreshToken}}`."
          },
          "response": []
        },
